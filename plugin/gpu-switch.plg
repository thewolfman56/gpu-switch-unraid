<?xml version="1.0"?>
<PLUGIN name="gpu-switch"
        author="thewolfman56"
        version="4.0.5"
        launch="Main/gpu-switch"
        pluginURL="https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/gpu-switch.plg"
        support="https://forums.unraid.net/topic/YOUR-THREAD"
        icon="cog">

  <DESCRIPTION>GPU Switch Manager with UI, Tdarr, and Multi-GPU mapping</DESCRIPTION>

  <FILE Run="/bin/mkdir -p /usr/local/emhttp/plugins/gpu-switch/include" />
  <FILE Run="/bin/mkdir -p /usr/local/emhttp/plugins/gpu-switch/logs" />
  <FILE Run="/bin/mkdir -p /usr/local/emhttp/plugins/gpu-switch/state" />

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/create-config.sh">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/create-config.sh</URL>
  </FILE>

  <FILE Run="/bin/bash /usr/local/emhttp/plugins/gpu-switch/create-config.sh" />

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/gpu-switch.page">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/gpu-switch.page</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/gpu-switch.sh">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/gpu-switch.sh</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/ui-status.sh">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/ui-status.sh</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/qemu-hook.php">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/qemu-hook.php</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/include/settings.php">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/include/settings.php</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/include/actions.php">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/include/actions.php</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/include/ui.js">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/include/ui.js</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/include/style.css">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/include/style.css</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/include/gpu_usage.php">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/include/gpu_usage.php</URL>
  </FILE>

  <FILE Name="/usr/local/emhttp/plugins/gpu-switch/include/test_tdarr.php">
  <URL>https://raw.githubusercontent.com/thewolfman56/gpu-switch-unraid/security-and-robustness-improvements/plugin/include/test_tdarr.php</URL>
  </FILE>

  <FILE Run="/bin/chmod +x /usr/local/emhttp/plugins/gpu-switch/gpu-switch.sh" />
  <FILE Run="/bin/chmod +x /usr/local/emhttp/plugins/gpu-switch/ui-status.sh" />

</PLUGIN>
